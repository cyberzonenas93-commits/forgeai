FORGEAI_ENV=beta
FORGEAI_APP_ENV=beta
FORGEAI_FIREBASE_PROJECT=forgeai-555ee
FORGEAI_FIREBASE_PROJECT_ID=forgeai-555ee
FORGEAI_FIREBASE_REGION=us-central1
FORGEAI_REQUIRED_PROVIDERS=github,openai
FORGEAI_ENFORCE_PROVIDER_SECRETS=false
FORGEAI_STRICT_ENV_VALIDATION=false
FORGEAI_TOKEN_VALUE_USD=0.05

OPENAI_API_KEY=replace-with-openai-key
# Tracks ChatGPT’s current GPT-5 snapshot; omit to use OPENAI_LATEST_CHAT_MODEL in code (gpt-5-chat-latest).
OPENAI_MODEL=gpt-5-chat-latest
OPENAI_INPUT_COST_PER_1K_USD=0.0004
OPENAI_OUTPUT_COST_PER_1K_USD=0.0016
OPENAI_OUTPUT_TO_INPUT_RATIO=0.35

ANTHROPIC_API_KEY=replace-with-anthropic-key
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
ANTHROPIC_INPUT_COST_PER_1K_USD=0.0030
ANTHROPIC_OUTPUT_COST_PER_1K_USD=0.0150
ANTHROPIC_OUTPUT_TO_INPUT_RATIO=0.35

GEMINI_API_KEY=replace-with-gemini-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_INPUT_COST_PER_1K_USD=0.00015
GEMINI_OUTPUT_COST_PER_1K_USD=0.00060
GEMINI_OUTPUT_TO_INPUT_RATIO=0.35

GITHUB_TOKEN=replace-with-github-service-token
