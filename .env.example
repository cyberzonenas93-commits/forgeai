# CodeCatalystAI app/runtime configuration
FORGEAI_ENV=beta
FORGEAI_FIREBASE_PROJECT_ID=forgeai-555ee
FORGEAI_FIREBASE_REGION=us-central1
FORGEAI_REQUIRED_PROVIDERS=openai
FORGEAI_BETA_CHANNEL=internal
FORGEAI_ENABLE_ANALYTICS=true
FORGEAI_ENABLE_CRASHLYTICS=true
FORGEAI_ENABLE_SCREENSHOT_STUDIO=false
FORGEAI_SCREENSHOT_SCENE=dashboard
FORGEAI_TOKEN_VALUE_USD=0.05

# Smoke-test inputs
SMOKE_TEST_FIREBASE_USER_EMAIL=
SMOKE_TEST_FIREBASE_USER_PASSWORD=
SMOKE_TEST_GITHUB_REPO=
SMOKE_TEST_BRANCH_PREFIX=beta/smoke/

# Release coordination
FORGEAI_IOS_SCHEME=Runner
FORGEAI_IOS_CONFIGURATION=Release
FORGEAI_ANDROID_APPLICATION_ID=com.forgeai.app
